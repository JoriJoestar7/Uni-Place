# Server
PORT=3000
NODE_ENV=production

# Frontend domains
# Use your final Vercel URL here, for example:
# FRONTEND_URL=https://uniplace-web.vercel.app/
FRONTEND_URL=https://uniplace-web.vercel.app/
# Optional comma-separated extra domains:
FRONTEND_URLS=

# Database
# Railway often provides DATABASE_URL or MYSQL_URL. Prefer DATABASE_URL in production.
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE
# Railway MySQL may also expose these variables:
MYSQLHOST=
MYSQLPORT=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQL_URL=
# Local fallback if you do not use DATABASE_URL:
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=uniplace_db

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=2h
JWT_REMEMBER_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# Gemini
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Mail through HTTPS (recommended for Railway Trial/Hobby)
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM="UniPlace <onboarding@resend.dev>"
SUPPORT_EMAIL=soporte@uniplace.app

# SMTP fallback (Railway Pro or local development)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_smtp_user
MAIL_PASS=your_smtp_password

# Verification
VERIFICATION_CODE_MINUTES=15
PASSWORD_RESET_CODE_MINUTES=15
